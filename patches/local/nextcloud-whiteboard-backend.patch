diff --git a/helmfile/apps/nextcloud/charts/nextcloud/templates/whiteboard-deployment.yaml b/helmfile/apps/nextcloud/charts/nextcloud/templates/whiteboard-deployment.yaml
new file mode 100644
index 0000000..f80ccc3
--- /dev/null
+++ b/helmfile/apps/nextcloud/charts/nextcloud/templates/whiteboard-deployment.yaml
@@ -0,0 +1,70 @@
+{{- if .Values.whiteboard.enabled }}
+apiVersion: apps/v1
+kind: Deployment
+metadata:
+  name: {{ include "common.names.fullname" . }}-whiteboard
+  namespace: {{ include "common.names.namespace" . | quote }}
+  labels: {{- include "common.labels.standard" (dict "customLabels" .Values.commonLabels "context" $) | nindent 4 }}
+    app.kubernetes.io/component: whiteboard
+spec:
+  replicas: 1
+  strategy:
+    type: Recreate
+  selector:
+    matchLabels: {{- include "common.labels.matchLabels" (dict "customLabels" .Values.commonLabels "context" $) | nindent 6 }}
+      app.kubernetes.io/component: whiteboard
+  template:
+    metadata:
+      labels: {{- include "common.labels.standard" (dict "customLabels" .Values.commonLabels "context" $) | nindent 8 }}
+        app.kubernetes.io/component: whiteboard
+    spec:
+      automountServiceAccountToken: false
+      securityContext:
+        runAsNonRoot: true
+        runAsUser: 65534
+        runAsGroup: 65534
+        fsGroup: 65534
+        seccompProfile:
+          type: RuntimeDefault
+      containers:
+        - name: whiteboard
+          image: {{ printf "%s/%s:%s@%s" .Values.whiteboard.image.registry .Values.whiteboard.image.repository .Values.whiteboard.image.tag .Values.whiteboard.image.digest | quote }}
+          imagePullPolicy: IfNotPresent
+          env:
+            - name: JWT_SECRET_KEY
+              valueFrom:
+                secretKeyRef:
+                  name: {{ include "common.names.fullname" . }}-whiteboard
+                  key: jwt-secret
+            - name: NEXTCLOUD_URL
+              value: {{ printf "https://%s" .Values.ingress.hostname | quote }}
+            - name: STORAGE_STRATEGY
+              value: lru
+            - name: HOST
+              value: 0.0.0.0
+          ports:
+            - name: http
+              containerPort: 3002
+              protocol: TCP
+          readinessProbe:
+            httpGet: { path: /, port: http }
+            periodSeconds: 10
+            timeoutSeconds: 3
+            failureThreshold: 6
+          livenessProbe:
+            httpGet: { path: /, port: http }
+            periodSeconds: 20
+            timeoutSeconds: 3
+            failureThreshold: 3
+          resources: {{- toYaml .Values.whiteboard.resources | nindent 12 }}
+          securityContext:
+            allowPrivilegeEscalation: false
+            readOnlyRootFilesystem: true
+            capabilities: { drop: ["ALL"] }
+          volumeMounts:
+            - name: tmp
+              mountPath: /tmp
+      volumes:
+        - name: tmp
+          emptyDir: {}
+{{- end }}
diff --git a/helmfile/apps/nextcloud/charts/nextcloud/templates/whiteboard-ingress.yaml b/helmfile/apps/nextcloud/charts/nextcloud/templates/whiteboard-ingress.yaml
new file mode 100644
index 0000000..75ff4b6
--- /dev/null
+++ b/helmfile/apps/nextcloud/charts/nextcloud/templates/whiteboard-ingress.yaml
@@ -0,0 +1,39 @@
+{{- if and .Values.whiteboard.enabled (eq .Values.cluster.routingMode "ingress") }}
+{{- if ne .Values.cluster.ingress.type "traefik" }}
+{{- fail "Nextcloud Whiteboard currently requires Traefik path-prefix routing" }}
+{{- end }}
+apiVersion: traefik.io/v1alpha1
+kind: Middleware
+metadata:
+  name: {{ include "common.names.fullname" . }}-whiteboard-strip-prefix
+  namespace: {{ include "common.names.namespace" . | quote }}
+spec:
+  stripPrefix:
+    prefixes: ["/whiteboard"]
+---
+apiVersion: networking.k8s.io/v1
+kind: Ingress
+metadata:
+  name: {{ include "common.names.fullname" . }}-whiteboard
+  namespace: {{ include "common.names.namespace" . | quote }}
+  labels: {{- include "common.labels.standard" (dict "customLabels" .Values.commonLabels "context" $) | nindent 4 }}
+    app.kubernetes.io/component: whiteboard
+  annotations:
+    traefik.ingress.kubernetes.io/router.priority: "100"
+    traefik.ingress.kubernetes.io/router.middlewares: '{{ include "common.names.namespace" . }}-hsts-header@kubernetescrd{{ if .Values.whiteboard.authGateMiddleware }},{{ .Values.whiteboard.authGateMiddleware }}{{ end }},{{ include "common.names.namespace" . }}-{{ include "common.names.fullname" . }}-whiteboard-strip-prefix@kubernetescrd'
+spec:
+  ingressClassName: {{ .Values.ingress.ingressClassName | quote }}
+  rules:
+    - host: {{ .Values.ingress.hostname | quote }}
+      http:
+        paths:
+          - path: /whiteboard
+            pathType: Prefix
+            backend:
+              service:
+                name: {{ include "common.names.fullname" . }}-whiteboard
+                port: { name: http }
+  {{- if .Values.ingress.extraTls }}
+  tls: {{- toYaml .Values.ingress.extraTls | nindent 4 }}
+  {{- end }}
+{{- end }}
diff --git a/helmfile/apps/nextcloud/charts/nextcloud/templates/whiteboard-networkpolicy.yaml b/helmfile/apps/nextcloud/charts/nextcloud/templates/whiteboard-networkpolicy.yaml
new file mode 100644
index 0000000..9fe77fb
--- /dev/null
+++ b/helmfile/apps/nextcloud/charts/nextcloud/templates/whiteboard-networkpolicy.yaml
@@ -0,0 +1,30 @@
+{{- if .Values.whiteboard.enabled }}
+apiVersion: networking.k8s.io/v1
+kind: NetworkPolicy
+metadata:
+  name: {{ include "common.names.fullname" . }}-whiteboard
+  namespace: {{ include "common.names.namespace" . | quote }}
+spec:
+  podSelector:
+    matchLabels: {{- include "common.labels.matchLabels" (dict "customLabels" .Values.commonLabels "context" $) | nindent 6 }}
+      app.kubernetes.io/component: whiteboard
+  policyTypes: [Ingress, Egress]
+  ingress:
+    - from:
+        - namespaceSelector:
+            matchLabels:
+              kubernetes.io/metadata.name: kube-system
+          podSelector:
+            matchLabels:
+              app.kubernetes.io/name: traefik
+      ports:
+        - { port: 3002, protocol: TCP }
+  egress:
+    - to:
+        - namespaceSelector:
+            matchLabels:
+              kubernetes.io/metadata.name: kube-system
+      ports:
+        - { port: 53, protocol: UDP }
+        - { port: 53, protocol: TCP }
+{{- end }}
diff --git a/helmfile/apps/nextcloud/charts/nextcloud/templates/whiteboard-secret.yaml b/helmfile/apps/nextcloud/charts/nextcloud/templates/whiteboard-secret.yaml
new file mode 100644
index 0000000..b36856e
--- /dev/null
+++ b/helmfile/apps/nextcloud/charts/nextcloud/templates/whiteboard-secret.yaml
@@ -0,0 +1,14 @@
+{{- if .Values.whiteboard.enabled }}
+apiVersion: v1
+kind: Secret
+metadata:
+  name: {{ include "common.names.fullname" . }}-whiteboard
+  namespace: {{ include "common.names.namespace" . | quote }}
+  labels: {{- include "common.labels.standard" (dict "customLabels" .Values.commonLabels "context" $) | nindent 4 }}
+    app.kubernetes.io/component: whiteboard
+  annotations:
+    helm.sh/resource-policy: keep
+type: Opaque
+data:
+  jwt-secret: {{ include "common.secrets.passwords.manage" (dict "secret" (printf "%s-whiteboard" (include "common.names.fullname" .)) "key" "jwt-secret" "providedValues" (list "whiteboard.jwtSecret") "length" 64 "strong" true "context" $) }}
+{{- end }}
diff --git a/helmfile/apps/nextcloud/charts/nextcloud/templates/whiteboard-service.yaml b/helmfile/apps/nextcloud/charts/nextcloud/templates/whiteboard-service.yaml
new file mode 100644
index 0000000..fba60ac
--- /dev/null
+++ b/helmfile/apps/nextcloud/charts/nextcloud/templates/whiteboard-service.yaml
@@ -0,0 +1,18 @@
+{{- if .Values.whiteboard.enabled }}
+apiVersion: v1
+kind: Service
+metadata:
+  name: {{ include "common.names.fullname" . }}-whiteboard
+  namespace: {{ include "common.names.namespace" . | quote }}
+  labels: {{- include "common.labels.standard" (dict "customLabels" .Values.commonLabels "context" $) | nindent 4 }}
+    app.kubernetes.io/component: whiteboard
+spec:
+  type: ClusterIP
+  selector: {{- include "common.labels.matchLabels" (dict "customLabels" .Values.commonLabels "context" $) | nindent 4 }}
+    app.kubernetes.io/component: whiteboard
+  ports:
+    - name: http
+      port: 3002
+      targetPort: http
+      protocol: TCP
+{{- end }}
