diff --git a/helmfile/apps/nextcloud/values.yaml.gotmpl b/helmfile/apps/nextcloud/values.yaml.gotmpl
index 21d9dcd..e659c0f 100644
--- a/helmfile/apps/nextcloud/values.yaml.gotmpl
+++ b/helmfile/apps/nextcloud/values.yaml.gotmpl
@@ -224,5 +224,31 @@ collabora:
 {{- end }}
-
+
+# Whiteboard v1.5.9 requires its websocket coordinator to designate the browser
+# that durably writes the Nextcloud file. Keep it same-origin and behind the
+# suite auth gate under /whiteboard.
+whiteboard:
+  enabled: true
+  collabBackendUrl: "https://{{ .Values.global.hostname.nextcloud }}.{{ .Values.global.domain }}/whiteboard"
+  jwtSecret: {{ derivePassword 1 "long" (requiredEnv "MIJNBUREAU_MASTER_PASSWORD") "nextcloud" "whiteboardJwtSecret" | sha1sum | quote }}
+  authGateMiddleware: '{{ if dig "opensuite" "authGate" "enabled" false .Values }}{{ .Values.application.bureaublad.namespace }}-opensuite-auth-gate@kubernetescrd{{ end }}'
+  image:
+    registry: {{ .Values.container.nextcloud.whiteboard.registry | quote }}
+    repository: {{ .Values.container.nextcloud.whiteboard.repository | quote }}
+    tag: {{ .Values.container.nextcloud.whiteboard.tag | quote }}
+    digest: {{ .Values.container.nextcloud.whiteboard.digest | quote }}
+  resources: {{ .Values.resource.nextcloud.whiteboard | default dict | toYaml | nindent 4 }}
+
+# The image's before-starting hook owns strict, repeatable app enablement and
+# config. Both the app and backend read the same retained Helm secret.
+extraEnvVars:
+  - name: WHITEBOARD_COLLAB_BACKEND_URL
+    value: "https://{{ .Values.global.hostname.nextcloud }}.{{ .Values.global.domain }}/whiteboard"
+  - name: WHITEBOARD_JWT_SECRET
+    valueFrom:
+      secretKeyRef:
+        name: nextcloud-whiteboard
+        key: jwt-secret
+
 # Default storage quota per user
 files:
   defaultQuota: {{ .Values.application.nextcloud.defaultQuota | default "10 GB" | quote }}
