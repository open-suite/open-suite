     OIDC_POST_LOGIN_REDIRECT_URI: {{ $baseUrl }}
     OIDC_POST_LOGOUT_REDIRECT_URI: {{ $baseUrl }}
     OIDC_TOKEN_ENDPOINT: {{ .Values.authentication.oidc.token_endpoint | quote }}
