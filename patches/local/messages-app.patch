+{{- $releaseId := now | unixEpoch }}
+{{- $hostname := printf "%s.%s" .Values.global.hostname.messages .Values.global.domain }}
+{{- $sslPostfix := ternary "s" "" (.Values.global.tls.enabled | default true) }}
+{{- $baseUrl := printf "http%s://%s" $sslPostfix $hostname }}
+{{- $portalUrl := printf "https://%s.%s/" .Values.global.hostname.bureaublad .Values.global.domain }}
+{{- $logoutRedirectUrl := printf "https://auth.%s/logout?rd=%s" .Values.global.domain (urlquery $portalUrl) }}
+{{- $redisUrl := printf "redis://default:%s@%s:%d/1" .Values.cache.messages.password .Values.cache.messages.host (.Values.cache.messages.port | int) -}}
+{{- $s3Endpoint := printf "http%s://%s:%d" (ternary "s" "" .Values.objectstore.messages.useSSL) .Values.objectstore.messages.endpoint (.Values.objectstore.messages.port | int) -}}
+{{- /* Server-to-server Keycloak base URL, derived from the backchannel token
+       endpoint so selfsigned installs keep talking plain HTTP in-cluster. */}}
+{{- $keycloakUrl := (splitList "/realms/" .Values.authentication.oidc.token_endpoint) | first }}
+
+commonLabels:
+  app.kubernetes.io/part-of: messages
+
+image:
+  registry: {{ (coalesce .Values.container.messages.registry .Values.container.default.registry) | quote }}
+  backend:
+    repository: {{ .Values.container.messages.backend.repository | quote }}
+    tag: {{ .Values.container.messages.backend.tag | quote }}
+  frontend:
+    repository: {{ .Values.container.messages.frontend.repository | quote }}
+    tag: {{ .Values.container.messages.frontend.tag | quote }}
+  mtaIn:
+    repository: {{ .Values.container.messages.mtaIn.repository | quote }}
+    tag: {{ .Values.container.messages.mtaIn.tag | quote }}
+  mtaOut:
+    repository: {{ .Values.container.messages.mtaOut.repository | quote }}
+    tag: {{ .Values.container.messages.mtaOut.tag | quote }}
+  opensearch:
+    registry: {{ .Values.container.messages.opensearch.registry | quote }}
+    repository: {{ .Values.container.messages.opensearch.repository | quote }}
+    tag: {{ .Values.container.messages.opensearch.tag | quote }}
+
+# No security.default context here: Postfix (mta-in/out) and OpenSearch cannot
+# run under the strict shared context (root master process / writable config);
+# the chart sets per-component contexts instead.
+
+jobs:
+  releaseSuffix: {{ $releaseId | quote }}
+
+backend:
+  keycloakNamespace: {{ .Values.application.keycloak.namespace | quote }}
+  envVars:
+    # Django core
+    DJANGO_CONFIGURATION: "Production"
+    DJANGO_SETTINGS_MODULE: "messages.settings"
+    DJANGO_SECRET_KEY: {{ .Values.application.messages.backend.django.secretKey | quote }}
+    # Public hostname plus the in-cluster service name mta-in's MDA calls use.
+    DJANGO_ALLOWED_HOSTS: "{{ $hostname }},messages-backend"
+    DJANGO_CSRF_TRUSTED_ORIGINS: {{ $baseUrl | quote }}
+    SALT_KEY: {{ .Values.application.messages.saltKey | quote }}
+    LANGUAGE_CODE: "en-us"
+    # English-only for now; hides the in-app language switch.
+    FRONTEND_FORCED_DEFAULT_LANGUAGE: "en"
+    FRONTEND_SILENT_LOGIN_ENABLED: "true"
+    LOGGING_LEVEL_HANDLERS_CONSOLE: "INFO"
+    LOGGING_LEVEL_LOGGERS_APP: "INFO"
+    LOGGING_LEVEL_LOGGERS_ROOT: "INFO"
+    # Database
+    DB_HOST: {{ .Values.database.messages.host | quote }}
+    DB_PORT: {{ .Values.database.messages.port | quote }}
+    DB_NAME: {{ .Values.database.messages.name | quote }}
+    DB_USER: {{ .Values.database.messages.user | quote }}
+    DB_PASSWORD: {{ .Values.database.messages.password | quote }}
+    # Cache + Celery broker
+    REDIS_URL: {{ $redisUrl | quote }}
+    CELERY_BROKER_URL: {{ $redisUrl | quote }}
+    # Search
+    OPENSEARCH_URL: "http://messages-opensearch:9200"
+    # Object storage (Django media + the two message stores)
+    AWS_S3_ENDPOINT_URL: {{ $s3Endpoint | quote }}
+    AWS_S3_ACCESS_KEY_ID: {{ .Values.objectstore.messages.username | quote }}
+    AWS_S3_SECRET_ACCESS_KEY: {{ .Values.objectstore.messages.rootPassword | quote }}
+    AWS_S3_SIGNATURE_VERSION: "s3v4"
+    AWS_STORAGE_BUCKET_NAME: {{ .Values.objectstore.messages.bucket | quote }}
+    STORAGE_MESSAGE_IMPORTS_ENDPOINT_URL: {{ $s3Endpoint | quote }}
+    STORAGE_MESSAGE_IMPORTS_BUCKET_NAME: {{ .Values.objectstore.messages.bucketImports | quote }}
+    STORAGE_MESSAGE_IMPORTS_ACCESS_KEY: {{ .Values.objectstore.messages.username | quote }}
+    STORAGE_MESSAGE_IMPORTS_SECRET_KEY: {{ .Values.objectstore.messages.rootPassword | quote }}
+    STORAGE_MESSAGE_BLOBS_ENDPOINT_URL: {{ $s3Endpoint | quote }}
+    STORAGE_MESSAGE_BLOBS_BUCKET_NAME: {{ .Values.objectstore.messages.bucketBlobs | quote }}
+    STORAGE_MESSAGE_BLOBS_ACCESS_KEY: {{ .Values.objectstore.messages.username | quote }}
+    STORAGE_MESSAGE_BLOBS_SECRET_KEY: {{ .Values.objectstore.messages.rootPassword | quote }}
+    STORAGES_STATICFILES_BACKEND: "django.contrib.staticfiles.storage.StaticFilesStorage"
+    # OIDC login (browser flow through the shared mijnbureau realm)
+    OIDC_OP_JWKS_ENDPOINT: {{ .Values.authentication.oidc.jwks_uri | quote }}
+    OIDC_OP_AUTHORIZATION_ENDPOINT: {{ .Values.authentication.oidc.authorization_endpoint | quote }}
+    OIDC_OP_TOKEN_ENDPOINT: {{ .Values.authentication.oidc.token_endpoint | quote }}
+    OIDC_OP_USER_ENDPOINT: {{ .Values.authentication.oidc.userinfo_endpoint | quote }}
+    # Keep the Django session through the RP-initiated Keycloak round trip so
+    # django-lasuite can validate callback state before clearing it.
+    ALLOW_LOGOUT_GET_METHOD: "true"
+    OIDC_OP_LOGOUT_ENDPOINT: {{ .Values.authentication.oidc.end_session_endpoint | quote }}
+    OIDC_RP_CLIENT_ID: {{ .Values.authentication.client.messages.client_id | quote }}
+    OIDC_RP_CLIENT_SECRET: {{ .Values.authentication.client.messages.client_secret | quote }}
+    OIDC_RP_SIGN_ALGO: "RS256"
+    OIDC_RP_SCOPES: "openid email"
+    OIDC_REDIRECT_ALLOWED_HOSTS: '["{{ $baseUrl }}"]'
+    LOGIN_REDIRECT_URL: {{ $baseUrl | quote }}
+    LOGIN_REDIRECT_URL_FAILURE: {{ $baseUrl | quote }}
+    LOGOUT_REDIRECT_URL: {{ $logoutRedirectUrl | quote }}
+    # Keycloak admin API (mailbox/group provisioning via service account)
+    IDENTITY_PROVIDER: "keycloak"
+    KEYCLOAK_URL: {{ $keycloakUrl | quote }}
+    KEYCLOAK_REALM: "mijnbureau"
+    KEYCLOAK_CLIENT_ID: {{ .Values.authentication.client.messagesRestApi.client_id | quote }}
+    KEYCLOAK_CLIENT_SECRET: {{ .Values.authentication.client.messagesRestApi.client_secret | quote }}
+    KEYCLOAK_GROUP_PATH_PREFIX: "/maildomain-"
+    {{- with .Values.application.messages.autojoinBaseDomain }}
+    # Auto-provision mailboxes for OIDC users at this base domain.
+    MESSAGES_TESTDOMAIN: {{ $.Values.global.domain | quote }}
+    MESSAGES_TESTDOMAIN_MAPPING_BASEDOMAIN: {{ . | quote }}
+    {{- end }}
+    # Mail pipeline
+    MDA_API_SECRET: {{ .Values.application.messages.mda.apiSecret | quote }}
+    MTA_OUT_MODE: "relay"
+    MTA_OUT_RELAY_HOST: "messages-mta-out:587"
+    MTA_OUT_RELAY_USERNAME: {{ .Values.application.messages.mtaOut.smtpUsername | quote }}
+    MTA_OUT_RELAY_PASSWORD: {{ .Values.application.messages.mtaOut.smtpPassword | quote }}
+    # System mail from the app itself (password resets etc.) goes out the same way.
+    DJANGO_EMAIL_HOST: "messages-mta-out"
+    DJANGO_EMAIL_PORT: "587"
+    DJANGO_EMAIL_HOST_USER: {{ .Values.application.messages.mtaOut.smtpUsername | quote }}
+    DJANGO_EMAIL_HOST_PASSWORD: {{ .Values.application.messages.mtaOut.smtpPassword | quote }}
+    DJANGO_EMAIL_USE_TLS: "true"
+    DJANGO_EMAIL_FROM: {{ printf "noreply@%s" .Values.global.domain | quote }}
+    DJANGO_EMAIL_BRAND_NAME: "Open Suite"
+
+mtaIn:
+  envVars:
+    MDA_API_BASE_URL: "http://messages-backend:8000/api/v1.0/"
+    MDA_API_SECRET: {{ .Values.application.messages.mda.apiSecret | quote }}
+    MAX_INCOMING_EMAIL_SIZE: "30000000"
+
+mtaOut:
+  envVars:
+    MYHOSTNAME: {{ printf "mail.%s" .Values.global.domain | quote }}
+    SMTP_USERNAME: {{ .Values.application.messages.mtaOut.smtpUsername | quote }}
+    SMTP_PASSWORD: {{ .Values.application.messages.mtaOut.smtpPassword | quote }}
+  # Outbound smarthost (e.g. Brevo) credentials come from this out-of-band
+  # secret when it exists: SMTP_RELAY_HOST/_USERNAME/_PASSWORD. Without it
+  # mta-out delivers directly, which a residential/VPS IP usually cannot.
+  relaySecretName: "messages-mta-out-relay"
+
+ingress:
+  enabled: true
+  hostname: {{ $hostname }}
+  ingressClassName: {{ .Values.cluster.ingress.className | quote }}
+  annotations:
+    {{- if .Values.cluster.ingress.annotations }}
+    {{ .Values.cluster.ingress.annotations | toYaml | nindent 4 }}
+    {{- end }}
+    {{- if eq .Values.cluster.ingress.type "traefik" }}
+    traefik.ingress.kubernetes.io/router.middlewares: '{{ .Release.Namespace }}-hsts-header@kubernetescrd{{ if dig "opensuite" "authGate" "enabled" false .Values }},{{ .Values.application.bureaublad.namespace }}-opensuite-auth-gate@kubernetescrd{{ end }}'
+    {{- end }}
+  tls: {{ .Values.global.tls.enabled | default true }}
+  selfSigned: {{ and .Values.global.tls.enabled .Values.global.tls.selfSigned | default false }}
diff --git a/helmfile/environments/default/application.yaml.gotmpl b/helmfile/environments/default/application.yaml.gotmpl
index 66df91a..88b04bb 100644
--- a/helmfile/environments/default/application.yaml.gotmpl
+++ b/helmfile/environments/default/application.yaml.gotmpl
@@ -97,6 +97,32 @@ application:
     yProvider:
       key: {{ derivePassword 1 "long" (requiredEnv "MIJNBUREAU_MASTER_PASSWORD") "docs" "yProviderKey" | sha1sum | quote }}
 
+  # messages is a JMAP-inspired webmail from LaSuite (Open Suite addition).
+  # Off by default: OpenSearch is the heavy dependency, and outbound mail
+  # needs DNS (MX/SPF/DKIM/DMARC) plus a smarthost relay to be useful.
+  messages:
+    enabled: false
+    namespace: ~
+    backend:
+      django:
+        secretKey: {{ print ( derivePassword 1 "long" (requiredEnv "MIJNBUREAU_MASTER_PASSWORD") "messages" "djangoSecretKey" | sha1sum ) ( derivePassword 1 "long" (requiredEnv "MIJNBUREAU_MASTER_PASSWORD") "messages" "djangoSecretKey2" | sha1sum ) | trunc 63 | quote }}
+    # Symmetric key(s) for encrypting stored data (settings SALT_KEY).
+    saltKey: {{ derivePassword 1 "long" (requiredEnv "MIJNBUREAU_MASTER_PASSWORD") "messages" "saltKey" | sha1sum | quote }}
+    # Shared secret between mta-in (Postfix) and the backend's MDA API.
+    mda:
+      apiSecret: {{ derivePassword 1 "long" (requiredEnv "MIJNBUREAU_MASTER_PASSWORD") "messages" "mdaApiSecret" | sha1sum | quote }}
+    # Credentials the backend uses to authenticate TO mta-out (its submission
+    # smarthost). The relay mta-out itself forwards through (e.g. Brevo) is
+    # configured out-of-band via the messages-mta-out-relay secret.
+    # When set, OIDC users whose email is at this base domain get an
+    # auto-provisioned mailbox <local>@<global.domain> on first login
+    # (upstream MESSAGES_TESTDOMAIN mechanism). Unset: mailboxes are
+    # provisioned by a maildomain admin.
+    autojoinBaseDomain: ~
+    mtaOut:
+      smtpUsername: "messages"
+      smtpPassword: {{ derivePassword 1 "long" (requiredEnv "MIJNBUREAU_MASTER_PASSWORD") "messages" "mtaOutSmtpPassword" | sha1sum | quote }}
+
   bureaublad:
     enabled: true
     namespace: ~
