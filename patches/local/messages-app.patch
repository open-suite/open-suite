+# Overrides for the shared Bitnami MinIO chart (../common/charts/minio).
+# Minimal override file; chart defaults cover the rest.
+global:
+  imageRegistry: {{ (coalesce .Values.container.minio.registry .Values.container.default.registry) | quote }}
+  {{- with (coalesce .Values.container.minio.imagePullSecret .Values.container.default.imagePullSecret) }}
+  imagePullSecrets:
+    - {{ . | quote }}
+  {{- end }}
+  defaultStorageClass: {{ (coalesce .Values.pvc.messages.minio.storageClass .Values.pvc.default.storageClass) | quote }}
+  security:
+    allowInsecureImages: true
+
+clusterDomain: {{ .Values.cluster.networking.domain | default "cluster.local" | quote }}
+
+image:
+  registry: {{ (coalesce .Values.container.minio.registry .Values.container.default.registry) | quote }}
+  repository: {{ .Values.container.minio.repository | default "bitnami/minio" | quote }}
+  tag: {{ .Values.container.minio.tag | default "2025.7.18-debian-12-r0" | quote }}
+
+auth:
+  rootUser: {{ .Values.objectstore.messages.username | quote }}
+  rootPassword: {{ .Values.objectstore.messages.rootPassword | quote }}
+
+defaultBuckets: {{ printf "%s,%s,%s" .Values.objectstore.messages.bucket .Values.objectstore.messages.bucketImports .Values.objectstore.messages.bucketBlobs | quote }}
+
+resourcesPreset: {{ .Values.global.resourcesPreset | quote }}
+podSecurityContext: {{ .Values.security.default.podSecurityContext | toYaml | nindent 2 }}
+containerSecurityContext: {{ .Values.security.default.containerSecurityContext | toYaml | nindent 2 }}
+
+persistence:
+  storageClass: {{ (coalesce .Values.pvc.messages.minio.storageClass .Values.pvc.default.storageClass) | quote }}
+  accessModes: {{ coalesce .Values.pvc.messages.minio.accessModes .Values.pvc.default.accessModes (list "ReadWriteOnce") | toYaml | nindent 4 }}
+  size: {{ coalesce .Values.pvc.messages.minio.size .Values.pvc.default.size "8Gi" }}
+
+# The chart's bundled object-browser console image tag does not exist on
+# Docker Hub; the console is unused here anyway (docs disables it too).
+console:
+  enabled: false
diff --git a/helmfile/apps/messages/values-postgresql.yaml.gotmpl b/helmfile/apps/messages/values-postgresql.yaml.gotmpl
