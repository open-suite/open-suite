+apiVersion: apps/v1
+kind: Deployment
+metadata:
+  name: {{ .Release.Name }}-worker
+  namespace: {{ .Release.Namespace | quote }}
+  labels: {{- include "messages.labels" (dict "component" "worker" "context" $) | nindent 4 }}
+spec:
+  replicas: {{ .Values.worker.replicaCount }}
+  selector:
+    matchLabels: {{- include "messages.selectorLabels" (dict "component" "worker" "context" $) | nindent 6 }}
+  template:
+    metadata:
+      labels: {{- include "messages.labels" (dict "component" "worker" "context" $) | nindent 8 }}
+      annotations:
+        checksum/env: {{ .Values.backend.envVars | toYaml | sha256sum }}
+    spec:
+      containers:
+        - name: worker
+          image: {{ include "messages.image" (dict "component" "backend" "context" $) }}
+          # Upstream's Celery wrapper (all queues + beat scheduler in one process).
+          command: ["python", "worker.py"]
+          envFrom:
+            - secretRef:
+                name: {{ .Release.Name }}-backend-env
+          resources: {{ .Values.worker.resources | toYaml | nindent 12 }}
