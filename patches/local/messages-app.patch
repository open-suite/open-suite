@@ -0,0 +1,54 @@
+bases:
+  - "../../bases/default.yaml.gotmpl"
+
+# La Suite Messages (webmail). Open Suite addition, authored from the upstream
+# suitenumerique/messages compose.yaml/env contract; consumes the published
+# ghcr.io/suitenumerique/messages-* images. Heavy dependency is OpenSearch
+# (runs single-node inside the messages chart at demo scale).
+releases:
+  - name: messages-postgresql
+    chart: ../common/charts/postgresql
+    version: "16.7.18"
+    {{- if .Values.application.messages.namespace }}
+    namespace: {{ .Values.application.messages.namespace }}
+    {{- end }}
+    installed: {{ and (eq .Environment.Name "demo") (.Values.application.messages.enabled) | toYaml }}
+    values:
+      - "values-postgresql.yaml.gotmpl"
+
+  - name: messages-redis
+    chart: ../common/charts/redis
+    version: "21.2.6"
+    {{- if .Values.application.messages.namespace }}
+    namespace: {{ .Values.application.messages.namespace }}
+    {{- end }}
+    installed: {{ and (eq .Environment.Name "demo") (.Values.application.messages.enabled) | toYaml }}
+    values:
+      - "values-redis.yaml.gotmpl"
+
+  - name: messages-minio
+    chart: ../common/charts/minio
+    version: "17.0.11"
+    {{- if .Values.application.messages.namespace }}
+    namespace: {{ .Values.application.messages.namespace }}
+    {{- end }}
+    installed: {{ and (eq .Environment.Name "demo") (.Values.application.messages.enabled) | toYaml }}
+    values:
+      - "../common/values-cluster-ingress.yaml.gotmpl"
+      - "values-minio.yaml.gotmpl"
+
+  - name: messages
+    chart: charts/messages
+    condition: application.messages.enabled
+    {{- if .Values.application.messages.namespace }}
+    namespace: {{ .Values.application.messages.namespace }}
+    {{- end }}
+    {{- if and (eq .Environment.Name "demo") (.Values.application.messages.enabled) }}
+    needs:
+      - {{ if .Values.application.messages.namespace }}{{ .Values.application.messages.namespace }}/{{ end }}messages-postgresql
+      - {{ if .Values.application.messages.namespace }}{{ .Values.application.messages.namespace }}/{{ end }}messages-redis
+      - {{ if .Values.application.messages.namespace }}{{ .Values.application.messages.namespace }}/{{ end }}messages-minio
+    {{- end }}
+    values:
+      - "../common/values-cluster-ingress.yaml.gotmpl"
+      - "values.yaml.gotmpl"
