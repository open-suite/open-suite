diff --git a/helmfile/apps/messages/charts/messages/templates/frontend-deployment.yaml b/helmfile/apps/messages/charts/messages/templates/frontend-deployment.yaml
new file mode 100644
index 0000000..6516f54
--- /dev/null
+++ b/helmfile/apps/messages/charts/messages/templates/frontend-deployment.yaml
@@ -0,0 +1,64 @@
+apiVersion: apps/v1
+kind: Deployment
+metadata:
+  name: {{ .Release.Name }}-frontend
+  namespace: {{ .Release.Namespace | quote }}
+  labels: {{- include "messages.labels" (dict "component" "frontend" "context" $) | nindent 4 }}
+spec:
+  replicas: {{ .Values.frontend.replicaCount }}
+  selector:
+    matchLabels: {{- include "messages.selectorLabels" (dict "component" "frontend" "context" $) | nindent 6 }}
+  template:
+    metadata:
+      labels: {{- include "messages.labels" (dict "component" "frontend" "context" $) | nindent 8 }}
+    spec:
+      containers:
+        - name: frontend
+          image: {{ include "messages.image" (dict "component" "frontend" "context" $) }}
+          env:
+            # Caddy inside the image proxies /api, /admin, /static and
+            # /__heartbeat__ to this address; everything else is the SPA.
+            - name: MESSAGES_FRONTEND_BACKEND_SERVER
+              value: "{{ .Release.Name }}-backend:8000"
+          ports:
+            - name: http
+              containerPort: 8080
+              protocol: TCP
+          livenessProbe:
+            httpGet:
+              path: /__lbheartbeat__
+              port: http
+            initialDelaySeconds: 5
+            periodSeconds: 15
+          readinessProbe:
+            httpGet:
+              path: /__lbheartbeat__
+              port: http
+            initialDelaySeconds: 3
+            periodSeconds: 10
+          resources: {{ .Values.frontend.resources | toYaml | nindent 12 }}
+        # Same-origin Open Suite header: nginx proxies the SPA and sub_filters
+        # a <script> tag into every HTML page — the same pattern the other
+        # apps get via patches/local/opensuite-header-sidecar.patch. The
+        # header JS configmap is uploaded by 09-portal-header.sh (optional:
+        # pages render headerless until it exists).
+        - name: opensuite-header
+          image: {{ .Values.frontend.headerSidecar.image | quote }}
+          ports:
+            - name: hdr
+              containerPort: 8091
+              protocol: TCP
+          volumeMounts:
+            - name: opensuite-header-conf
+              mountPath: /etc/nginx/nginx.conf
+              subPath: nginx.conf
+            - name: opensuite-header-js
+              mountPath: /usr/share/opensuite
+      volumes:
+        - name: opensuite-header-conf
+          configMap:
+            name: opensuite-header-conf
+        - name: opensuite-header-js
+          configMap:
+            name: opensuite-header-js
+            optional: true
