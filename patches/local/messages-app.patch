diff --git a/helmfile/apps/messages/charts/messages/templates/mta-out-deployment.yaml b/helmfile/apps/messages/charts/messages/templates/mta-out-deployment.yaml
new file mode 100644
index 0000000..5d2f114
--- /dev/null
+++ b/helmfile/apps/messages/charts/messages/templates/mta-out-deployment.yaml
@@ -0,0 +1,58 @@
+apiVersion: apps/v1
+kind: Deployment
+metadata:
+  name: {{ .Release.Name }}-mta-out
+  namespace: {{ .Release.Namespace | quote }}
+  labels: {{- include "messages.labels" (dict "component" "mta-out" "context" $) | nindent 4 }}
+spec:
+  replicas: {{ .Values.mtaOut.replicaCount }}
+  selector:
+    matchLabels: {{- include "messages.selectorLabels" (dict "component" "mta-out" "context" $) | nindent 6 }}
+  template:
+    metadata:
+      labels: {{- include "messages.labels" (dict "component" "mta-out" "context" $) | nindent 8 }}
+      annotations:
+        checksum/env: {{ .Values.mtaOut.envVars | toYaml | sha256sum }}
+    spec:
+      containers:
+        - name: mta-out
+          image: {{ include "messages.image" (dict "component" "mtaOut" "context" $) }}
+          # Repairs for the published 0.8.0 image (all fixed upstream on main):
+          # /var/spool/postfix/etc is missing (the entrypoint needs it for the
+          # SASL db); private/public ship root-owned, which kills postfix
+          # master; and main.cf.j2 indents the relay-auth lines, which postfix
+          # folds into the relayhost value as continuation lines, silently
+          # disabling SASL auth to the smarthost.
+          command:
+            - bash
+            - -c
+            - >-
+              mkdir -p /var/spool/postfix/etc &&
+              chown -R postfix /var/spool/postfix/private /var/spool/postfix/public &&
+              chgrp -R postdrop /var/spool/postfix/public &&
+              sed -i 's/^ //' /app/etc/main.cf.j2 &&
+              exec /usr/local/bin/entrypoint.sh
+          ports:
+            - name: submission
+              containerPort: 587
+              protocol: TCP
+          envFrom:
+            - secretRef:
+                name: {{ .Release.Name }}-mta-out-env
+            # Smarthost relay credentials (SMTP_RELAY_HOST/_USERNAME/_PASSWORD),
+            # created out-of-band — see overlays/messages/ in the open-suite
+            # repo. Optional: without it mta-out attempts direct MX delivery.
+            - secretRef:
+                name: {{ .Values.mtaOut.relaySecretName }}
+                optional: true
+          readinessProbe:
+            tcpSocket:
+              port: submission
+            initialDelaySeconds: 5
+            periodSeconds: 10
+          livenessProbe:
+            tcpSocket:
+              port: submission
+            initialDelaySeconds: 15
+            periodSeconds: 20
+          resources: {{ .Values.mtaOut.resources | toYaml | nindent 12 }}
