+++ b/helmfile/apps/messages/charts/messages/values.yaml
@@ -0,0 +1,84 @@
+# Default values for the messages chart. The deploy-time source of truth is
+# ../../values.yaml.gotmpl (rendered by helmfile); these defaults only make
+# `helm lint`/`helm template` work standalone and document the shape.
+
+image:
+  registry: "ghcr.io"
+  backend:
+    repository: "open-suite/messages-backend"
+    tag: "v0.8.0-opensuite.1"
+  frontend:
+    repository: "open-suite/messages-frontend"
+    tag: "v0.8.0-opensuite.1"
+  mtaIn:
+    repository: "suitenumerique/messages-mta-in"
+    tag: "0.8.0"
+  mtaOut:
+    repository: "suitenumerique/messages-mta-out"
+    tag: "0.8.0"
+  opensearch:
+    registry: "docker.io"
+    repository: "opensearchproject/opensearch"
+    tag: "2.19.2"
+
+commonLabels: {}
+
+jobs:
+  # Changed every release so the migrate job re-runs on upgrade.
+  releaseSuffix: "0"
+
+backend:
+  replicaCount: 1
+  keycloakNamespace: "mb-keycloak"
+  # Full Django environment (secrets included) — stored in one Secret that the
+  # backend, worker and migrate job all envFrom.
+  envVars: {}
+  resources: {}
+
+worker:
+  replicaCount: 1
+  resources: {}
+
+frontend:
+  replicaCount: 1
+  resources: {}
+  # Same-origin Open Suite header sidecar (nginx sub_filter), matching the
+  # pattern the other apps get via patches. The header JS configmap is
+  # uploaded by 09-portal-header.sh and optional.
+  headerSidecar:
+    image: "nginxinc/nginx-unprivileged:1.27-alpine"
+
+mtaIn:
+  replicaCount: 1
+  envVars: {}
+  resources: {}
+  # Inbound SMTP: exposed on the node's port 25 (single-node deploy; Traefik
+  # does not carry raw TCP without extra entrypoints).
+  hostPort: 25
+
+mtaOut:
+  replicaCount: 1
+  envVars: {}
+  resources: {}
+  # Optional out-of-band Secret carrying SMTP_RELAY_HOST/_USERNAME/_PASSWORD
+  # for the upstream smarthost (e.g. Brevo).
+  relaySecretName: "messages-mta-out-relay"
+
+opensearch:
+  javaOpts: "-Xms512m -Xmx1g"
+  persistence:
+    size: "8Gi"
+    storageClass: ""
+  resources: {}
+
+ingress:
+  enabled: true
+  hostname: "messages.example.com"
+  ingressClassName: ""
+  annotations: {}
+  tls: true
+  selfSigned: false
+
+cluster:
+  ingress:
+    type: "traefik"
diff --git a/helmfile/apps/messages/helmfile-child.yaml.gotmpl b/helmfile/apps/messages/helmfile-child.yaml.gotmpl
