index 0000000..b997a8d
--- /dev/null
+++ b/helmfile/apps/messages/charts/messages/templates/_helpers.tpl
@@ -0,0 +1,25 @@
+{{/* Standard labels for a component. Usage:
+     {{ include "messages.labels" (dict "component" "backend" "context" $) }} */}}
+{{- define "messages.labels" -}}
+app.kubernetes.io/name: messages
+app.kubernetes.io/instance: {{ .context.Release.Name }}
+app.kubernetes.io/component: {{ .component }}
+app.kubernetes.io/managed-by: Helm
+{{- with .context.Values.commonLabels }}
+{{ toYaml . }}
+{{- end }}
+{{- end -}}
+
+{{/* Selector labels (stable subset). */}}
+{{- define "messages.selectorLabels" -}}
+app.kubernetes.io/name: messages
+app.kubernetes.io/instance: {{ .context.Release.Name }}
+app.kubernetes.io/component: {{ .component }}
+{{- end -}}
+
+{{/* Image reference for a component under .Values.image. */}}
+{{- define "messages.image" -}}
+{{- $img := index .context.Values.image .component -}}
+{{- $registry := $img.registry | default .context.Values.image.registry -}}
+{{- printf "%s/%s:%s" $registry $img.repository $img.tag -}}
+{{- end -}}
diff --git a/helmfile/apps/messages/charts/messages/templates/backend-deployment.yaml b/helmfile/apps/messages/charts/messages/templates/backend-deployment.yaml
new file mode 100644
index 0000000..492e65c
--- /dev/null
+++ b/helmfile/apps/messages/charts/messages/templates/backend-deployment.yaml
@@ -0,0 +1,42 @@
+apiVersion: apps/v1
+kind: Deployment
+metadata:
+  name: {{ .Release.Name }}-backend
+  namespace: {{ .Release.Namespace | quote }}
+  labels: {{- include "messages.labels" (dict "component" "backend" "context" $) | nindent 4 }}
+spec:
+  replicas: {{ .Values.backend.replicaCount }}
+  selector:
+    matchLabels: {{- include "messages.selectorLabels" (dict "component" "backend" "context" $) | nindent 6 }}
+  template:
+    metadata:
+      labels: {{- include "messages.labels" (dict "component" "backend" "context" $) | nindent 8 }}
+      annotations:
+        checksum/env: {{ .Values.backend.envVars | toYaml | sha256sum }}
+    spec:
+      containers:
+        - name: backend
+          image: {{ include "messages.image" (dict "component" "backend" "context" $) }}
+          ports:
+            - name: http
+              containerPort: 8000
+              protocol: TCP
+          envFrom:
+            - secretRef:
+                name: {{ .Release.Name }}-backend-env
+          # /__heartbeat__/ checks the DB connection; it is SSL-redirect exempt
+          # and the pod IP is in ALLOWED_HOSTS (Production adds
+          # gethostbyname(hostname)), so a plain httpGet works.
+          livenessProbe:
+            httpGet:
+              path: /__heartbeat__/
+              port: http
+            initialDelaySeconds: 30
+            periodSeconds: 15
+          readinessProbe:
+            httpGet:
+              path: /__heartbeat__/
+              port: http
+            initialDelaySeconds: 10
+            periodSeconds: 10
+          resources: {{ .Values.backend.resources | toYaml | nindent 12 }}
diff --git a/helmfile/apps/messages/charts/messages/templates/backend-keycloak-networkpolicy.yaml b/helmfile/apps/messages/charts/messages/templates/backend-keycloak-networkpolicy.yaml
new file mode 100644
index 0000000..8bea444
--- /dev/null
+++ b/helmfile/apps/messages/charts/messages/templates/backend-keycloak-networkpolicy.yaml
@@ -0,0 +1,25 @@
+# The single-VPS namespace egress whitelist deliberately blocks cross-namespace
+# traffic. Permit only the backend's OIDC/admin calls to Keycloak's HTTP port.
+apiVersion: networking.k8s.io/v1
+kind: NetworkPolicy
+metadata:
+  name: {{ .Release.Name }}-backend-keycloak-egress
+  namespace: {{ .Release.Namespace | quote }}
+  labels: {{- include "messages.labels" (dict "component" "backend" "context" $) | nindent 4 }}
+spec:
+  podSelector:
+    matchLabels: {{- include "messages.selectorLabels" (dict "component" "backend" "context" $) | nindent 6 }}
+  policyTypes: [Egress]
+  egress:
+    - to:
+        - namespaceSelector:
+            matchLabels:
+              kubernetes.io/metadata.name: {{ .Values.backend.keycloakNamespace | quote }}
+          podSelector:
+            matchLabels:
+              app.kubernetes.io/name: keycloak
+              app.kubernetes.io/component: keycloak
+      ports:
+        # NetworkPolicy evaluates the Service's post-DNAT container port.
+        - port: 8080
+          protocol: TCP
