diff --git a/helmfile/apps/messages/charts/messages/templates/opensearch-statefulset.yaml b/helmfile/apps/messages/charts/messages/templates/opensearch-statefulset.yaml
new file mode 100644
index 0000000..fd52a5e
--- /dev/null
+++ b/helmfile/apps/messages/charts/messages/templates/opensearch-statefulset.yaml
@@ -0,0 +1,79 @@
+# Single-node OpenSearch for message search. The vendored infra carries no
+# OpenSearch chart, and at single-VPS scale one node with the security plugin
+# disabled (cluster-internal traffic only) is the honest deployment.
+apiVersion: apps/v1
+kind: StatefulSet
+metadata:
+  name: {{ .Release.Name }}-opensearch
+  namespace: {{ .Release.Namespace | quote }}
+  labels: {{- include "messages.labels" (dict "component" "opensearch" "context" $) | nindent 4 }}
+spec:
+  serviceName: {{ .Release.Name }}-opensearch
+  replicas: 1
+  selector:
+    matchLabels: {{- include "messages.selectorLabels" (dict "component" "opensearch" "context" $) | nindent 6 }}
+  template:
+    metadata:
+      labels: {{- include "messages.labels" (dict "component" "opensearch" "context" $) | nindent 8 }}
+    spec:
+      initContainers:
+        # OpenSearch refuses to start below vm.max_map_count=262144; stock
+        # Ubuntu ships 65530. Node-level sysctl, hence the privileged init.
+        - name: sysctl
+          image: busybox:1.36
+          command: ["sysctl", "-w", "vm.max_map_count=262144"]
+          securityContext:
+            privileged: true
+      containers:
+        - name: opensearch
+          image: {{ include "messages.image" (dict "component" "opensearch" "context" $) }}
+          env:
+            - name: discovery.type
+              value: "single-node"
+            - name: DISABLE_INSTALL_DEMO_CONFIG
+              value: "true"
+            - name: DISABLE_SECURITY_PLUGIN
+              value: "true"
+            - name: OPENSEARCH_JAVA_OPTS
+              value: {{ .Values.opensearch.javaOpts | quote }}
+          ports:
+            - name: http
+              containerPort: 9200
+              protocol: TCP
+          volumeMounts:
+            - name: data
+              mountPath: /usr/share/opensearch/data
+          # OpenSearch can take several minutes to cold-start on the minimum
+          # supported host. Do not let liveness restart that valid startup;
+          # after cluster health succeeds, the existing probes are unchanged.
+          startupProbe:
+            # Plain HTTP matches the disabled security plugin above.
+            httpGet:
+              path: /_cluster/health
+              port: http
+            periodSeconds: 10
+            timeoutSeconds: 5
+            failureThreshold: 60
+          readinessProbe:
+            httpGet:
+              path: /_cluster/health
+              port: http
+            initialDelaySeconds: 20
+            periodSeconds: 10
+          livenessProbe:
+            tcpSocket:
+              port: http
+            initialDelaySeconds: 60
+            periodSeconds: 20
+          resources: {{ .Values.opensearch.resources | toYaml | nindent 12 }}
+  volumeClaimTemplates:
+    - metadata:
+        name: data
+      spec:
+        accessModes: ["ReadWriteOnce"]
+        {{- with .Values.opensearch.persistence.storageClass }}
+        storageClassName: {{ . | quote }}
+        {{- end }}
+        resources:
+          requests:
+            storage: {{ .Values.opensearch.persistence.size | quote }}
