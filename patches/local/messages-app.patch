diff --git a/helmfile/apps/messages/charts/messages/templates/header-configmap.yaml b/helmfile/apps/messages/charts/messages/templates/header-configmap.yaml
new file mode 100644
index 0000000..0eae212
--- /dev/null
+++ b/helmfile/apps/messages/charts/messages/templates/header-configmap.yaml
@@ -0,0 +1,70 @@
+# nginx config for the Open Suite header sidecar — identical to the
+# opensuite-header-conf the other apps get via
+# patches/local/opensuite-header-sidecar.patch, with the upstream port set to
+# this app's Caddy (8080).
+apiVersion: v1
+kind: ConfigMap
+metadata:
+  name: opensuite-header-conf
+  namespace: {{ .Release.Namespace | quote }}
+  labels:
+    app.kubernetes.io/part-of: open-suite
+    app.kubernetes.io/component: opensuite-header
+data:
+  nginx.conf: |
+    worker_processes 1;
+    pid /tmp/nginx.pid;            # nginx-unprivileged runs as uid 101
+    events { worker_connections 1024; }
+    http {
+      include /etc/nginx/mime.types;
+      # Upstream compression is disabled so sub_filter can inspect HTML.
+      # Recompress eligible responses here before sending them to clients.
+      gzip on;
+      gzip_vary on;
+      gzip_proxied any;
+      gzip_min_length 1024;
+      gzip_comp_level 5;
+      gzip_types text/plain text/css text/javascript text/xml application/javascript application/json application/xml image/svg+xml application/wasm;
+      client_body_temp_path /tmp/client_temp;
+      proxy_temp_path /tmp/proxy_temp;
+      fastcgi_temp_path /tmp/fastcgi_temp;
+      uwsgi_temp_path /tmp/uwsgi_temp;
+      scgi_temp_path /tmp/scgi_temp;
+      # Carry over the upstream CSP nonce so the injected script runs under
+      # 'strict-dynamic'; empty/harmless when there's no CSP.
+      map $upstream_http_content_security_policy $ko_nonce {
+        default "";
+        "~nonce-(?<n>[A-Za-z0-9+/=_-]+)" $n;
+      }
+      map $http_upgrade $connection_upgrade {
+        default upgrade;
+        "" close;
+      }
+      server {
+        listen 8091;
+        client_max_body_size 0;
+        location = /opensuite-header.js {
+          default_type application/javascript;
+          # no-cache = revalidate per page view (cheap 304). The JS configmap is
+          # updated in place by 09-portal-header.sh; there is no versioned URL.
+          add_header Cache-Control "no-cache";
+          alias /usr/share/opensuite/opensuite-header.js;
+        }
+        location / {
+          proxy_pass http://127.0.0.1:8080;
+          proxy_http_version 1.1;
+          proxy_set_header Upgrade $http_upgrade;
+          proxy_set_header Connection $connection_upgrade;
+          proxy_buffering off;
+          proxy_set_header Host $host;
+          proxy_set_header X-Real-IP $remote_addr;
+          proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
+          proxy_set_header X-Forwarded-Proto $scheme;
+          proxy_set_header Accept-Encoding "";   # so sub_filter can rewrite the body
+          proxy_read_timeout 300s;
+          proxy_redirect off;
+          sub_filter '</body>' '<script nonce="$ko_nonce" src="/opensuite-header.js"></script></body>';
+          sub_filter_once on;
+        }
+      }
+    }
diff --git a/helmfile/apps/messages/charts/messages/templates/ingress.yaml b/helmfile/apps/messages/charts/messages/templates/ingress.yaml
new file mode 100644
index 0000000..7bfb47f
--- /dev/null
+++ b/helmfile/apps/messages/charts/messages/templates/ingress.yaml
@@ -0,0 +1,34 @@
+{{- if .Values.ingress.enabled }}
+apiVersion: networking.k8s.io/v1
+kind: Ingress
+metadata:
+  name: {{ .Release.Name }}
+  namespace: {{ .Release.Namespace | quote }}
+  labels: {{- include "messages.labels" (dict "component" "frontend" "context" $) | nindent 4 }}
+  {{- with .Values.ingress.annotations }}
+  annotations: {{ . | toYaml | nindent 4 }}
+  {{- end }}
+spec:
+  {{- with .Values.ingress.ingressClassName }}
+  ingressClassName: {{ . | quote }}
+  {{- end }}
+  rules:
+    - host: {{ .Values.ingress.hostname | quote }}
+      http:
+        paths:
+          # The frontend's Caddy fans out /api, /admin and /static to the
+          # backend itself, so one route covers the whole app.
+          - path: /
+            pathType: Prefix
+            backend:
+              service:
+                name: {{ .Release.Name }}-frontend
+                port:
+                  name: http
+  {{- if .Values.ingress.tls }}
+  tls:
+    - hosts:
+        - {{ .Values.ingress.hostname | quote }}
+      secretName: {{ printf "%s-tls" .Values.ingress.hostname | quote }}
+  {{- end }}
+{{- end }}
diff --git a/helmfile/apps/messages/charts/messages/templates/migrate-job.yaml b/helmfile/apps/messages/charts/messages/templates/migrate-job.yaml
new file mode 100644
index 0000000..9808302
--- /dev/null
+++ b/helmfile/apps/messages/charts/messages/templates/migrate-job.yaml
@@ -0,0 +1,63 @@
+# Django migrations, re-run on every helmfile apply (releaseSuffix changes per
+# release render). Runs as a plain Job rather than a helm hook so a bare
+# `helmfile apply` owns it and a failed migration surfaces in the release.
+apiVersion: batch/v1
+kind: Job
+metadata:
+  name: {{ .Release.Name }}-migrate-{{ .Values.jobs.releaseSuffix }}
+  namespace: {{ .Release.Namespace | quote }}
+  labels: {{- include "messages.labels" (dict "component" "migrate" "context" $) | nindent 4 }}
+spec:
+  backoffLimit: 3
+  activeDeadlineSeconds: 1200
+  ttlSecondsAfterFinished: 3600
+  template:
+    metadata:
+      labels: {{- include "messages.labels" (dict "component" "migrate" "context" $) | nindent 8 }}
+    spec:
+      restartPolicy: Never
+      # A release dependency only orders Helm operations; it does not prove a
+      # new database stayed up. Require six successful connections over 30s
+      # before migrating; this fixed durability gate is not a performance knob.
+      initContainers:
+        - name: wait-for-postgresql
+          image: {{ include "messages.image" (dict "component" "backend" "context" $) }}
+          command: ["python", "-c"]
+          args:
+            - |
+              import os
+              import time
+
+              import psycopg
+
+              deadline = time.monotonic() + 600
+              stable = 0
+              while time.monotonic() < deadline:
+                  try:
+                      with psycopg.connect(
+                          host=os.environ["DB_HOST"],
+                          port=os.environ["DB_PORT"],
+                          dbname=os.environ["DB_NAME"],
+                          user=os.environ["DB_USER"],
+                          password=os.environ["DB_PASSWORD"],
+                          connect_timeout=5,
+                      ) as connection:
+                          connection.execute("SELECT 1")
+                      stable += 1
+                      if stable >= 6:
+                          break
+                  except psycopg.OperationalError:
+                      stable = 0
+                  time.sleep(5)
+              else:
+                  raise SystemExit("PostgreSQL did not stay ready for 30 seconds within 10 minutes")
+          envFrom:
+            - secretRef:
+                name: {{ .Release.Name }}-backend-env
+      containers:
+        - name: migrate
+          image: {{ include "messages.image" (dict "component" "backend" "context" $) }}
+          command: ["python", "manage.py", "migrate", "--no-input"]
+          envFrom:
+            - secretRef:
+                name: {{ .Release.Name }}-backend-env
diff --git a/helmfile/apps/messages/charts/messages/templates/mta-in-deployment.yaml b/helmfile/apps/messages/charts/messages/templates/mta-in-deployment.yaml
new file mode 100644
index 0000000..137c369
--- /dev/null
+++ b/helmfile/apps/messages/charts/messages/templates/mta-in-deployment.yaml
@@ -0,0 +1,43 @@
+apiVersion: apps/v1
+kind: Deployment
+metadata:
+  name: {{ .Release.Name }}-mta-in
+  namespace: {{ .Release.Namespace | quote }}
+  labels: {{- include "messages.labels" (dict "component" "mta-in" "context" $) | nindent 4 }}
+spec:
+  replicas: {{ .Values.mtaIn.replicaCount }}
+  strategy:
+    # hostPort 25 can only be bound by one pod per node.
+    type: Recreate
+  selector:
+    matchLabels: {{- include "messages.selectorLabels" (dict "component" "mta-in" "context" $) | nindent 6 }}
+  template:
+    metadata:
+      labels: {{- include "messages.labels" (dict "component" "mta-in" "context" $) | nindent 8 }}
+      annotations:
+        checksum/env: {{ .Values.mtaIn.envVars | toYaml | sha256sum }}
+    spec:
+      containers:
+        - name: mta-in
+          image: {{ include "messages.image" (dict "component" "mtaIn" "context" $) }}
+          ports:
+            - name: smtp
+              containerPort: 25
+              # Inbound mail lands on the node's public IP directly (single-node
+              # deploy; Traefik carries no raw-TCP entrypoint for SMTP).
+              hostPort: {{ .Values.mtaIn.hostPort }}
+              protocol: TCP
+          envFrom:
+            - secretRef:
+                name: {{ .Release.Name }}-mta-in-env
+          readinessProbe:
+            tcpSocket:
+              port: smtp
+            initialDelaySeconds: 5
+            periodSeconds: 10
+          livenessProbe:
+            tcpSocket:
+              port: smtp
+            initialDelaySeconds: 15
+            periodSeconds: 20
+          resources: {{ .Values.mtaIn.resources | toYaml | nindent 12 }}
