@@ -0,0 +1,57 @@
+# Overrides for the shared Bitnami PostgreSQL chart (../common/charts/postgresql).
+# Unlike the older apps this is a minimal override file, not a full copy of the
+# chart's values.yaml — the chart's own defaults cover everything else.
+global:
+  imageRegistry: ""
+  {{- with (coalesce .Values.container.postgres.imagePullSecret .Values.container.default.imagePullSecret) }}
+  imagePullSecrets:
+    - {{ . | quote }}
+  {{- end }}
+  defaultStorageClass: {{ coalesce .Values.pvc.messages.postgresql.storageClass .Values.pvc.default.storageClass | quote }}
+  storageClass: {{ coalesce .Values.pvc.messages.postgresql.storageClass .Values.pvc.default.storageClass | quote }}
+  security:
+    allowInsecureImages: true
+
+# Same host name convention as the cnpg-based apps (…-cluster-rw) so
+# database.messages.host works regardless of provider.
+fullnameOverride: "messages-cluster-rw"
+
+clusterDomain: {{ .Values.cluster.networking.domain | default "cluster.local" | quote }}
+
+image:
+  registry: {{ coalesce .Values.container.postgres.registry .Values.container.default.registry | default "docker.io" | quote }}
+  repository: {{ .Values.container.postgres.repository | default "bitnami/postgresql" | quote }}
+  tag: {{ .Values.container.postgres.tag | default "17.5.0-debian-12-r18" | quote }}
+  pullPolicy: Always
+  {{- with (coalesce .Values.container.postgres.imagePullSecret .Values.container.default.imagePullSecret) }}
+  pullSecrets:
+    - {{ . | quote }}
+  {{- end }}
+
+auth:
+  postgresPassword: {{ .Values.database.messages.adminpassword | quote }}
+  username: {{ .Values.database.messages.user | quote }}
+  password: {{ .Values.database.messages.password | quote }}
+  database: {{ .Values.database.messages.name | quote }}
+
+architecture: standalone
+
+primary:
+  resourcesPreset: {{ .Values.global.resourcesPreset | quote }}
+  resources: {{ .Values.resource.messages.postgresql | default dict | toYaml | nindent 4 }}
+  # First initialization took four minutes under measured standard-runner
+  # load. Suppress liveness until PostgreSQL has actually started instead of
+  # carrying pre-start failures into the migration window.
+  startupProbe:
+    enabled: true
+    initialDelaySeconds: 0
+    periodSeconds: 10
+    timeoutSeconds: 5
+    failureThreshold: 60
+    successThreshold: 1
+  podSecurityContext: {{ .Values.security.default.podSecurityContext | toYaml | nindent 4 }}
+  containerSecurityContext: {{ .Values.security.default.containerSecurityContext | toYaml | nindent 4 }}
+  persistence:
+    storageClass: {{ coalesce .Values.pvc.messages.postgresql.storageClass .Values.pvc.default.storageClass | quote }}
+    accessModes: {{ coalesce .Values.pvc.messages.postgresql.accessModes .Values.pvc.default.accessModes (list "ReadWriteOnce") | toYaml | nindent 6 }}
+    size: {{ coalesce .Values.pvc.messages.postgresql.size .Values.pvc.default.size "8Gi" }}
