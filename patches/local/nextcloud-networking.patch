diff --git a/helmfile/apps/nextcloud/values.yaml.gotmpl b/helmfile/apps/nextcloud/values.yaml.gotmpl
index 706e9e2..ba9a46c 100644
--- a/helmfile/apps/nextcloud/values.yaml.gotmpl
+++ b/helmfile/apps/nextcloud/values.yaml.gotmpl
@@ -180,7 +180,21 @@ mail:
 trustedDomains:
   - {{ .Values.global.hostname.nextcloud }}.{{ .Values.global.domain }}
 
-trustedProxies: {{ .Values.cluster.networking.serviceSubnet | toYaml | nindent 2 }}
+# Open Suite: include the pod subnet — Traefik pods proxy from there, not from
+# the service subnet. Without it Nextcloud sees every request as one internal
+# IP: all users share a single rate-limit bucket and client IPs log wrong.
+# 127.0.0.1: the opensuite-header sidecar proxies to the app container over
+# localhost; without trusting it Nextcloud cannot walk X-Forwarded-For and
+# sees every caller as 127.0.0.1 (breaking the WOPI pod-subnet allowlist).
+trustedProxies: {{ concat .Values.cluster.networking.serviceSubnet .Values.cluster.networking.podSubnet (list "127.0.0.1") | toYaml | nindent 2 }}
+
+# Open Suite: CoreDNS rewrites *.DOMAIN to the in-cluster Traefik ClusterIP, a
+# private IP, and Nextcloud's SSRF guard refuses server-side requests to
+# private IPs by default — OIDC discovery would fail and login 404.
+extraConfigs:
+  opensuite.config.php: |
+    <?php
+    $CONFIG['allow_local_remote_servers'] = true;
 
 forwardedForHeaders:
   - "X-Forwarded-For"
@@ -220,7 +234,11 @@ persistence:
 # The is the URL is used to connect Collabora Server with Next Cloud Office App automaticlly
 collabora:
   url: "https://{{ .Values.global.hostname.collabora | default "collabora" }}.{{ .Values.global.domain | default "example.com"  }}"
-  wopi_allowlist: {{ index .Values.cluster.networking.podSubnet 0 }}
+  # 127.0.0.1: with the header sidecar in front, an all-trusted forwarded
+  # chain (Collabora is in the pod subnet = trusted_proxies) resolves to the
+  # sidecar's localhost. External callers resolve to their public IP and stay
+  # blocked either way.
+  wopi_allowlist: "{{ index .Values.cluster.networking.podSubnet 0 }},127.0.0.1"
 {{- end }}
 
 # Default storage quota per user
