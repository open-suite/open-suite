+# Open Suite: same-origin header sidecar (ticket 3.5). An nginx sidecar
+# proxies the app and sub_filters a <script> tag for the shared portal header
+# into every HTML page, stamping the per-request CSP nonce. The header JS
+# itself lives in the `opensuite-header-js` configmap uploaded by
+# 09-portal-header.sh (optional: pages render headerless until it exists).
 frontend:
+  sidecars:
+    - name: opensuite-header
+      image: nginxinc/nginx-unprivileged:1.27-alpine
+      volumeMounts:
+        - name: opensuite-header-conf
+          mountPath: /etc/nginx/nginx.conf
+          subPath: nginx.conf
+        - name: opensuite-header-js
