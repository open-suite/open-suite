diff --git a/helmfile/apps/nextcloud/charts/nextcloud/templates/configmap-script-post-install.yaml b/helmfile/apps/nextcloud/charts/nextcloud/templates/configmap-script-post-install.yaml
index 5b9cd96..173d033 100644
--- a/helmfile/apps/nextcloud/charts/nextcloud/templates/configmap-script-post-install.yaml
+++ b/helmfile/apps/nextcloud/charts/nextcloud/templates/configmap-script-post-install.yaml
@@ -54,6 +54,17 @@ data:
     # Enable the bureaublad button app (files are mounted from a ConfigMap at custom_apps/bureaublad_button)
     php /var/www/html/occ app:enable bureaublad_button || echo "WARNING: Failed to enable bureaublad_button"
 
+    # Calendar <-> Meet: enable the meetcal app (files mounted from a ConfigMap at custom_apps/meetcal)
+    php /var/www/html/occ app:enable meetcal || echo "WARNING: Failed to enable meetcal"
+    # Store the OIDC login token so meetcal can exchange it for a Meet-audience token.
+    php /var/www/html/occ config:app:set user_oidc store_login_token --value=1
+    # user_oidc requests requested_token_type=refresh_token, which Keycloak 26's standard
+    # token exchange rejects; Meet only needs the access token, so request access_token.
+    USER_OIDC_TS=/var/www/html/custom_apps/user_oidc/lib/Service/TokenService.php
+    if [ -f "$USER_OIDC_TS" ]; then
+      sed -i "s#requested_token_type. => .urn:ietf:params:oauth:token-type:refresh_token#requested_token_type' => 'urn:ietf:params:oauth:token-type:access_token#g" "$USER_OIDC_TS"
+    fi
+
     php /var/www/html/occ config:system:set maintenance_window_start --type=integer --value=1
     php /var/www/html/occ config:system:set default_phone_region --value=NL
 
