diff --git a/src/frontend/src/features/message/use-delete-trashed.tsx b/src/frontend/src/features/message/use-delete-trashed.tsx
new file mode 100644
index 0000000..e5878ed
--- /dev/null
+++ b/src/frontend/src/features/message/use-delete-trashed.tsx
@@ -0,0 +1,32 @@
+import { useTranslation } from "react-i18next";
+import { useMailboxContext } from "../providers/mailbox";
+import useDelete from "./use-delete";
+
+/**
+ * Hook to permanently delete messages that are already in Trash.
+ */
+const useDeleteTrashed = () => {
+    const { t } = useTranslation();
+    const { invalidateMailbox, invalidateThreadsStats } = useMailboxContext();
+
+    const { remove, status } = useDelete("trashed", {
+        toastMessage: (deletedCount) => {
+            if (deletedCount === 0) return t("No trashed message could be deleted.");
+            return t("{{count}} trashed messages have been permanently deleted.", {
+                count: deletedCount,
+                defaultValue_one: "The trashed message has been permanently deleted.",
+            });
+        },
+        onSuccess: () => {
+            invalidateMailbox();
+            invalidateThreadsStats();
+        },
+    });
+
+    return {
+        deleteTrashed: remove,
+        status,
+    };
+};
+
+export default useDeleteTrashed;
